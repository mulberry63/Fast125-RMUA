<launch>
	<arg name="uavname" default="fpv" />

	<node pkg="Ctrl" type="Ctrl_node" name="Ctrl" output="screen">
        <!-- <remap from="~odom" to="/airsim_node/drone_1/odom_local_enu" /> -->
		<rosparam command="load" file="$(find rpg_mpc)/parameters/default.yaml" />
      	<rosparam file="$(find rpg_mpc)/parameters/hummingbird.yaml" />
		<remap from="~odom" to="/odom" />
		<remap from="~cmd" to="/position_cmd" />
		<remap from="~traj_cmd" to="/traj_cmd" />
		<remap from="~imu" to="/airsim_node/drone_1/imu/imu" />
        <rosparam command="load" file="$(find Ctrl)/config/ctrl_param_$(arg uavname).yaml" />
	</node>

  <node pkg="state_transform" name="st_node" type="st_node" output="screen">
        <remap from="~input_odom" to="/airsim_node/drone_1/odom_local_ned"/>
        <!-- <remap from="~output_odom" to="/odom"/> -->
        <remap from="~input_cmd" to="/setpoint_raw/attitude"/>
        <remap from="~output_posecmd" to="/airsim_node/drone_1/pose_cmd_body_frame"/>
        <remap from="~output_bodyratecmd" to="/airsim_node/drone_1/angle_rate_throttle_frame"/>
  </node>

</launch>
